<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen">

<ScrollView
    android:id="@+id/contentScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- ===================== HEADER ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp"
            android:paddingBottom="6dp">

            <View
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/logo_badge" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="v1.0"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- status pill -->
            <LinearLayout
                android:id="@+id/statusPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/pill_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="14dp"
                android:paddingTop="7dp"
                android:paddingBottom="7dp">

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_offline" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Offline"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===================== LIVE PREVIEW ===================== -->
        <FrameLayout
            android:id="@+id/previewCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/card_panel"
            android:padding="12dp">

            <LinearLayout
                android:id="@+id/previewCardInner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/previewHeaderRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="4dp"
                    android:paddingBottom="10dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_usb" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Live Scanner Feed"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/fpsBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/pill_bg"
                        android:backgroundTint="@null"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:text="-- fps"
                        android:textColor="@color/accent_cyan"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/fullscreenButton"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/btn_primary"
                        android:backgroundTint="@null"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="Fullscreen"
                        android:textAllCaps="false"
                        android:textColor="#04181C"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/previewHost"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:background="@drawable/preview_frame">

                    <TextView
                        android:id="@+id/previewPlaceholder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:text="@string/waiting_camera"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />
                </FrameLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- ===================== SCANNER CONTROLS ===================== -->
        <LinearLayout
            android:id="@+id/controlsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/card_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/controlsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SCANNER CONTROLS"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <TextView
                    android:id="@+id/controlsToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/controlsBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Adjust if the scanner image is dark or blurry so the QR can be read."
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"
                    android:paddingBottom="8dp" />

                <!-- toggles -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <CheckBox
                        android:id="@+id/cbAutoWb"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Auto WB"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:checked="true" />
                </LinearLayout>

                <!-- sliders -->
                <TextView android:id="@+id/lblBrightness" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Brightness" android:textColor="@color/text_secondary" android:textSize="11sp" android:paddingTop="6dp"/>
                <SeekBar android:id="@+id/sbBrightness" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="60"/>

                <TextView android:id="@+id/lblExposure" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Exposure" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/sbExposure" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="50"/>

                <TextView android:id="@+id/lblContrast" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Contrast" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/sbContrast" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="60"/>

                <TextView android:id="@+id/lblSaturation" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Saturation" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/sbSaturation" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="60"/>

                <TextView android:id="@+id/lblGain" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Gain" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/sbGain" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="50"/>

                <TextView android:id="@+id/lblSharpness" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sharpness" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/sbSharpness" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="50"/>

                <TextView android:id="@+id/lblZoom" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Zoom" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/sbZoom" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="0"/>

                <TextView android:id="@+id/lblWbTemp" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="WB Temp" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/sbWbTemp" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="50"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ===================== PAIRING (SCAN PC) ===================== -->
        <LinearLayout
            android:id="@+id/pairingCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/card_panel"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PAIR WITH PC"
                android:textColor="@color/accent_cyan"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />

            <TextView
                android:id="@+id/scanHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tap Scan PC Code, then aim the phone camera at the QR code."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingExtra="3dp" />

            <!-- step chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="10dp"
                    android:text="1.  On the PC: Wireless tab \u2192 Pair phone (QR)"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2.  Tap Scan PC Code below"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="3.  Aim the phone camera at the QR code \u2014 it connects automatically"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===================== ACTION BUTTONS ===================== -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/actionButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/btn_primary"
            android:backgroundTint="@null"
            android:drawableStart="@drawable/ic_stream"
            android:drawablePadding="10dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="Scan PC Code"
            android:textColor="#04181C"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/btn_danger"
            android:backgroundTint="@null"
            android:text="Stop"
            android:textColor="#FF8A8A"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:visibility="gone"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>

    <!-- ===================== FULLSCREEN OVERLAY ===================== -->
    <FrameLayout
        android:id="@+id/fullscreenOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- top-right control buttons, overlaid on the video -->
        <LinearLayout
            android:id="@+id/fullscreenControlsBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/fsToggleControlsButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:background="@drawable/pill_bg"
                android:backgroundTint="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Controls"
                android:textAllCaps="false"
                android:textColor="@color/accent_cyan"
                android:textSize="12sp"
                android:textStyle="bold"
                android:stateListAnimator="@null" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/fsExitButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/btn_primary"
                android:backgroundTint="@null"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Exit"
                android:textAllCaps="false"
                android:textColor="#04181C"
                android:textSize="12sp"
                android:textStyle="bold"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- floating scanner-controls panel shown/hidden by the Controls button.
             Uses an explicitly declared linear copy of controls to maintain static layout size. -->
        <ScrollView
            android:id="@+id/fsControlsScroll"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="68dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/card_panel"
            android:padding="16dp"
            android:scrollbars="none"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/fsControlsHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Adjust if the scanner image is dark or blurry so the QR can be read."
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"
                    android:paddingBottom="8dp" />

                <!-- toggles -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <CheckBox
                        android:id="@+id/fsCbAutoWb"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Auto WB"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:checked="true" />
                </LinearLayout>

                <!-- sliders -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Brightness" android:textColor="@color/text_secondary" android:textSize="11sp" android:paddingTop="6dp"/>
                <SeekBar android:id="@+id/fsSbBrightness" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="60"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Exposure" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/fsSbExposure" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="50"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Contrast" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/fsSbContrast" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="60"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Saturation" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/fsSbSaturation" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="60"/>

                <TextView android:id="@+id/fsLblGain" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Gain" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/fsSbGain" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="50"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sharpness" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/fsSbSharpness" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="50"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Zoom" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/fsSbZoom" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="0"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="WB Temp" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <SeekBar android:id="@+id/fsSbWbTemp" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="50"/>

            </LinearLayout>
        </ScrollView>
    </FrameLayout>

</FrameLayout>